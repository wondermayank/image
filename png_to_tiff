<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PNG to TIFF Converter — Paste, Drop, or Upload | Wondermayank</title>
<meta name="description" content="Convert PNG images to TIFF instantly in your browser. Paste with Ctrl+V, drag and drop, or click to upload. Uncompressed, lossless, no server upload.">
<link rel="icon" type="image/svg+xml" href="https://wondermayank.github.io/favicon.svg">
<style>
  :root{--primary:#573AFC;--primary-active:#4527E0;--ink:#1d1d1f;--body:#3c3c3c;--muted:#6b6b6b;--muted-soft:#9a9a9a;--hairline:#e6e6e6;--hairline-strong:#cccccc;--canvas:#ffffff;--canvas-parchment:#f5f5f7;--on-primary:#ffffff;}
  [data-theme="dark"]{--ink:#f5f5f7;--body:#d1d1d6;--muted:#8e8e93;--muted-soft:#636366;--hairline:#2c2c2e;--hairline-strong:#3a3a3c;--canvas:#0e0e10;--canvas-parchment:#161618;--primary:#9A7AFB;--primary-active:#7C5CF0;}
  *{box-sizing:border-box;}
  body{margin:0;font-family:Inter,system-ui,-apple-system,sans-serif;background:var(--canvas-parchment);color:var(--ink);min-height:100vh;display:flex;flex-direction:column;align-items:center;transition:background .2s,color .2s;}
  header{width:100%;max-width:680px;padding:28px 20px 8px;display:flex;align-items:center;justify-content:space-between;}
  .brand{display:flex;align-items:center;gap:10px;font-weight:700;font-size:17px;letter-spacing:-0.1px;}
  .brand img{width:26px;height:26px;border-radius:6px;}
  .theme-toggle{width:40px;height:40px;border-radius:9999px;border:1px solid var(--hairline-strong);background:var(--canvas);display:flex;align-items:center;justify-content:center;cursor:pointer;}
  .theme-toggle svg{width:18px;height:18px;stroke:var(--ink);}
  main{width:100%;max-width:680px;padding:24px 20px 60px;flex:1;display:flex;flex-direction:column;align-items:center;}
  h1{font-size:28px;font-weight:700;letter-spacing:-0.2px;margin:10px 0 6px;text-align:center;}
  p.lead{font-size:16px;font-weight:400;color:var(--muted);text-align:center;margin:0 0 28px;max-width:480px;}
  .dropzone{width:100%;min-height:260px;border:2px dashed var(--hairline-strong);border-radius:18px;background:var(--canvas);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;cursor:pointer;padding:32px 20px;transition:border-color .15s,background .15s,transform .1s;}
  .dropzone:active{transform:scale(0.99);}
  .dropzone.drag-over{border-color:var(--primary);background:color-mix(in srgb, var(--primary) 6%, var(--canvas));}
  .dropzone svg{width:42px;height:42px;stroke:var(--primary);margin-bottom:14px;}
  .dz-title{font-size:17px;font-weight:600;margin:0 0 6px;}
  .dz-sub{font-size:14px;color:var(--muted);margin:0;line-height:1.5;}
  .dz-sub kbd{font-family:inherit;background:var(--canvas-parchment);border:1px solid var(--hairline-strong);border-radius:5px;padding:1px 6px;font-size:13px;}
  input[type="file"]{display:none;}
  .preview-card{width:100%;margin-top:24px;background:var(--canvas);border:1px solid var(--hairline);border-radius:18px;padding:20px;display:none;}
  .preview-card.show{display:block;}
  .preview-img-wrap{width:100%;border-radius:11px;overflow:hidden;background:repeating-conic-gradient(#cccccc 0% 25%, var(--canvas-parchment) 0% 50%) 50% / 20px 20px;display:flex;align-items:center;justify-content:center;max-height:320px;}
  .preview-img-wrap img{max-width:100%;max-height:320px;display:block;}
  .file-meta{display:flex;justify-content:space-between;align-items:center;margin-top:14px;font-size:14px;color:var(--muted);}
  .file-meta strong{color:var(--ink);font-weight:600;}
  .info-row{margin-top:14px;font-size:13px;color:var(--muted-soft);line-height:1.5;}
  .actions{display:flex;gap:12px;margin-top:20px;flex-wrap:wrap;}
  .btn{flex:1;min-width:140px;height:48px;border-radius:9999px;border:none;font-size:15px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:transform .1s,background .15s;}
  .btn:active{transform:scale(0.95);}
  .btn-primary{background:var(--primary);color:var(--on-primary);}
  .btn-primary:hover{background:var(--primary-active);}
  .btn-secondary{background:var(--canvas);color:var(--ink);border:1px solid var(--hairline-strong);}
  .btn svg{width:18px;height:18px;}
  .toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--ink);color:var(--canvas);padding:12px 20px;border-radius:9999px;font-size:14px;font-weight:600;opacity:0;pointer-events:none;transition:opacity .2s,transform .2s;z-index:50;}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
  footer{width:100%;text-align:center;padding:18px;font-size:12px;color:var(--muted-soft);}
  @media (max-width:480px){h1{font-size:23px;} .dropzone{min-height:220px;} .btn{min-width:0;}}
</style>
</head>
<body>

<header>
  <div class="brand"><img src="https://wondermayank.github.io/favicon.svg" alt=""><span>PNG → TIFF</span></div>
  <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode"><svg id="themeIcon" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></svg></button>
</header>

<main>
  <h1>PNG to TIFF Converter</h1>
  <p class="lead">Paste, drop, or click to convert to uncompressed TIFF — fully lossless, all in your browser.</p>

  <div class="dropzone" id="dropzone" tabindex="0" role="button" aria-label="Upload, paste, or drop a PNG image">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
    <p class="dz-title">Drop your PNG here</p>
    <p class="dz-sub">or click to browse &nbsp;·&nbsp; or press <kbd>Ctrl</kbd> + <kbd>V</kbd> to paste</p>
  </div>
  <input type="file" id="fileInput" accept="image/png,image/*">

  <div class="preview-card" id="previewCard">
    <div class="preview-img-wrap"><img id="previewImg" alt="Image preview"></div>
    <div class="file-meta"><span id="fileName">image.tiff</span><strong id="fileSize">—</strong></div>
    <div class="info-row">TIFF is saved uncompressed (RGBA, 8-bit) for maximum compatibility with design and print software. Files are larger than PNG — that's expected.</div>
    <div class="actions">
      <button class="btn btn-secondary" id="clearBtn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>Clear</button>
      <button class="btn btn-primary" id="downloadBtn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Download TIFF</button>
    </div>
  </div>
</main>

<footer>© 2026 Thunder · by wondermayank</footer>
<div class="toast" id="toast">Converted!</div>

<script>
(function(){
  const dropzone=document.getElementById('dropzone'),fileInput=document.getElementById('fileInput'),previewCard=document.getElementById('previewCard'),previewImg=document.getElementById('previewImg'),fileNameEl=document.getElementById('fileName'),fileSizeEl=document.getElementById('fileSize'),downloadBtn=document.getElementById('downloadBtn'),clearBtn=document.getElementById('clearBtn'),toast=document.getElementById('toast'),themeToggle=document.getElementById('themeToggle'),themeIcon=document.getElementById('themeIcon');
  let currentImage=null,currentName='image';

  const sunPath='<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
  const moonPath='<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>';
  function applyTheme(t){document.documentElement.setAttribute('data-theme',t);themeIcon.innerHTML=t==='dark'?sunPath:moonPath;localStorage.setItem('theme',t);}
  applyTheme(localStorage.getItem('theme')||(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light'));
  themeToggle.addEventListener('click',()=>applyTheme(document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark'));

  function showToast(msg){toast.textContent=msg;toast.classList.add('show');setTimeout(()=>toast.classList.remove('show'),1800);}
  function formatBytes(b){if(b<1024)return b+' B';if(b<1024*1024)return (b/1024).toFixed(1)+' KB';return (b/(1024*1024)).toFixed(2)+' MB';}

  function loadImageFile(file){
    if(!file||!file.type.startsWith('image/')){showToast('Please use an image file');return;}
    currentName=(file.name||'image').replace(/\.[^/.]+$/,'');
    const reader=new FileReader();
    reader.onload=(e)=>{
      currentImage=new Image();
      currentImage.onload=()=>{
        previewImg.src=e.target.result;
        fileNameEl.textContent=currentName+'.tiff';
        previewCard.classList.add('show');
        previewCard.scrollIntoView({behavior:'smooth',block:'nearest'});
        const w=currentImage.naturalWidth,h=currentImage.naturalHeight;
        const approxBytes=w*h*4+1024; // RGBA + header overhead
        fileSizeEl.textContent='TIFF ≈ '+formatBytes(approxBytes);
      };
      currentImage.src=e.target.result;
    };
    reader.readAsDataURL(file);
  }

  // Minimal baseline-TIFF (uncompressed RGBA, 8-bit, little-endian) encoder.
  function buildTiff(imageData,width,height){
    const pixelDataOffset=8+2+12*10+4; // header(8) + IFD entry count(2) + 10 entries*12 + next-IFD ptr(4)
    const ifdEntryCount=10;
    const headerSize=8;
    const ifdSize=2+ifdEntryCount*12+4;
    const totalHeaderSize=headerSize+ifdSize;
    const pixelBytes=width*height*4;
    const buffer=new ArrayBuffer(totalHeaderSize+pixelBytes);
    const view=new DataView(buffer);
    let off=0;
    // --- Header ---
    view.setUint16(off,0x4949,true);off+=2; // 'II' little endian
    view.setUint16(off,42,true);off+=2;     // TIFF magic
    view.setUint32(off,8,true);off+=4;      // offset to first IFD

    // --- IFD ---
    view.setUint16(off,ifdEntryCount,true);off+=2;

    function writeEntry(tag,type,count,value){
      view.setUint16(off,tag,true);off+=2;
      view.setUint16(off,type,true);off+=2;
      view.setUint32(off,count,true);off+=4;
      if(type===3&&count===1){ view.setUint16(off,value,true); off+=4; }
      else { view.setUint32(off,value,true); off+=4; }
    }
    // Tags must be written in ascending numeric order per spec
    writeEntry(256,3,1,width);              // ImageWidth
    writeEntry(257,3,1,height);             // ImageLength
    writeEntry(258,3,1,8);                  // BitsPerSample (single value here; real per-channel array omitted for simplicity, viewers default to 8)
    writeEntry(259,3,1,1);                  // Compression = none
    writeEntry(262,3,1,2);                  // PhotometricInterpretation = RGB
    writeEntry(273,4,1,totalHeaderSize);    // StripOffsets
    writeEntry(277,3,1,4);                  // SamplesPerPixel = 4 (RGBA)
    writeEntry(278,3,1,height);             // RowsPerStrip
    writeEntry(279,4,1,pixelBytes);         // StripByteCounts
    writeEntry(338,3,1,2);                  // ExtraSamples = unassociated alpha

    view.setUint32(off,0,true);off+=4; // next IFD = none

    // --- Pixel data (already RGBA from canvas, byte order matches) ---
    const px=new Uint8Array(buffer,totalHeaderSize);
    px.set(imageData.data);

    return buffer;
  }

  function getTiffBlob(){
    const w=currentImage.naturalWidth,h=currentImage.naturalHeight;
    const canvas=document.createElement('canvas');
    canvas.width=w;canvas.height=h;
    const ctx=canvas.getContext('2d');
    ctx.drawImage(currentImage,0,0);
    const imageData=ctx.getImageData(0,0,w,h);
    const buffer=buildTiff(imageData,w,h);
    return new Blob([buffer],{type:'image/tiff'});
  }

  dropzone.addEventListener('click',()=>fileInput.click());
  dropzone.addEventListener('keydown',(e)=>{if(e.key==='Enter'||e.key===' '){e.preventDefault();fileInput.click();}});
  fileInput.addEventListener('change',(e)=>{if(e.target.files&&e.target.files[0])loadImageFile(e.target.files[0]);});

  ['dragenter','dragover'].forEach(evt=>dropzone.addEventListener(evt,(e)=>{e.preventDefault();dropzone.classList.add('drag-over');}));
  ['dragleave','drop'].forEach(evt=>dropzone.addEventListener(evt,(e)=>{e.preventDefault();dropzone.classList.remove('drag-over');}));
  dropzone.addEventListener('drop',(e)=>{const file=e.dataTransfer.files&&e.dataTransfer.files[0];if(file)loadImageFile(file);});
  ['dragover','drop'].forEach(evt=>window.addEventListener(evt,(e)=>e.preventDefault()));

  window.addEventListener('paste',(e)=>{
    const items=e.clipboardData&&e.clipboardData.items;if(!items)return;
    for(const item of items){if(item.type.indexOf('image')!==-1){loadImageFile(item.getAsFile());break;}}
  });

  downloadBtn.addEventListener('click',()=>{
    if(!currentImage)return;
    const blob=getTiffBlob();
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a');a.href=url;a.download=currentName+'.tiff';
    document.body.appendChild(a);a.click();document.body.removeChild(a);
    setTimeout(()=>URL.revokeObjectURL(url),1000);
    showToast('Downloaded as TIFF');
  });

  clearBtn.addEventListener('click',()=>{currentImage=null;previewCard.classList.remove('show');fileInput.value='';});
})();
</script>
</body>
</html>
